{
  "expo": {
    "name": "Habcat",
    "slug": "habcat",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "habcat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "11",
      "appleTeamId": "D8DX35HW6N",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.corychambers.habcat"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FDFBF7",
        "foregroundImage": "./assets/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.corychambers.habcat",
      "versionCode": 6
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#FDFBF7"
        }
      ],
      [
        "expo-signed",
        {
          "store_file": {
            "key": "HABCAT_UPLOAD_STORE_FILE",
            "value": "release.keystore"
          },
          "key_alias": {
            "key": "HABCAT_UPLOAD_KEY_ALIAS",
            "value": "habcat"
          },
          "store_password": {
            "key": "HABCAT_UPLOAD_STORE_PASSWORD",
            "value": ""
          },
          "key_password": {
            "key": "HABCAT_UPLOAD_KEY_PASSWORD",
            "value": ""
          },
          "keystorePath": "."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
